# Server Configuration
NODE_ENV=development
PORT=3001

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Google OAuth 2.0 Credentials
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Required OAuth Scopes (do not change unless you know what you're doing)
GOOGLE_SCOPES=profile,email,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.modify

# Logging
LOG_LEVEL=info

# Token Encryption (for storing OAuth tokens)
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-change-in-prod

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Gmail API Settings
GMAIL_MAX_RESULTS=100
GMAIL_SYNC_INTERVAL_MS=60000

# WebSocket Settings
WEBSOCKET_ENABLED=true
WEBSOCKET_CORS_ORIGIN=http://localhost:3000