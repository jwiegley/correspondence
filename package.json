{
  "name": "correspondence",
  "version": "1.0.0",
  "private": true,
  "description": "Gmail correspondence viewer for processing emails with Notify and Action-Item labels",
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/shared"
  ],
  "scripts": {
    "preinstall": "npm run check:env",
    "postinstall": "npm run setup:env",
    "check:env": "node scripts/check-env.js || true",
    "setup:env": "node scripts/setup-env.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "npm run build --workspace=shared",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "docker:up": "bash scripts/start-all.sh",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "npm run docker:down && npm run docker:up",
    "wait:services": "node scripts/wait-for-services.js",
    "start": "npm run docker:up",
    "stop": "npm run docker:down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@playwright/test": "^1.55.0"
  }
}
